# ── Core ─────────────────────────────────────────────────────────────────────
SUPREME_APP_NAME=Supreme AI Agent OS
SUPREME_WORKSPACE_DIR=./data
SUPREME_ALLOW_TERMINAL=true
SUPREME_API_URL=http://127.0.0.1:8000
SUPREME_PUBLIC_URL=http://127.0.0.1:3000
SUPREME_DB_DIR=./data/state
UAC_ROOT=./data/.supreme-os

# ── Ollama (default LLM — zero API keys required) ────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Models auto-detected. To pre-pull: docker compose exec ollama ollama pull qwen2.5

# ── Cloud LLM (optional — system works without these) ────────────────────────
# XAI_API_KEY=
# XAI_MODEL=grok-2-latest
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=

# ── AWS Bedrock (optional) ────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# ── Telegram (optional) ───────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=123456789,987654321

# ── Redis (optional — SQLite used by default) ─────────────────────────────────
# REDIS_URL=redis://redis:6379/0

# ── Search (optional) ─────────────────────────────────────────────────────────
# TAVILY_API_KEY=
# SERPER_API_KEY=
# FIRECRAWL_API_KEY=
# BRAVE_SEARCH_API_KEY=

# ── Browser (optional) ────────────────────────────────────────────────────────
# Browser engine auto-selected: playwright_system > playwright_bundled > playwright_remote > selenium > httpx
BROWSERLESS_URL=ws://localhost:3001  # local Docker Browserless endpoint
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium         # set automatically in Docker

# ── Payments (optional) ───────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=

# ── Guardrails ────────────────────────────────────────────────────────────────
GUARDRAILS_STRICT=true
WARDEN_APPROVAL_THRESHOLD=100

# ── GitHub (optional) ─────────────────────────────────────────────────────────
# GITHUB_TOKEN=

# ── Finance (optional) ────────────────────────────────────────────────────────
# ALPHA_VANTAGE_API_KEY=
# POLYGON_API_KEY=
# COINGECKO_API_KEY=
